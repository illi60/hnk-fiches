// ============================================================
// Hi no Kuni — Fiches Techniques
// Schéma : User (RP + sync forum) · FicheTechnique · XPTransaction
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime serverless (Vercel) → Transaction pooler Supabase (port 6543)
  url       = env("DATABASE_URL")
  // Migrations Prisma → Direct connection Supabase (port 5432)
  // Sur Neon ou Postgres local, mets la même valeur que DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  USER
  ADMIN
  TECH_MOD // Modérateur technique : valide/refuse les fiches, sans autre pouvoir admin.
}

// Rang shinobi (verrouillé : E → S, cf. CdC §9)
enum Rang {
  E
  D
  C
  B
  A
  S
}

// Grade institutionnel
enum Grade {
  GENIN
  CHUNIN
  JONIN
}

// Workflow d'une fiche technique
enum FicheStatus {
  DRAFT      // en cours d'écriture par le joueur
  PENDING    // soumise, en attente de modération
  VALIDATED  // approuvée par le staff (XP débité à ce moment)
  REJECTED   // refusée (motif obligatoire)
}

// Voie de progression (3 axes parallèles : Village / Clan / Histoire)
enum ProgressionTrack {
  VILLAGE
  CLAN
  HISTOIRE
}

// Degré d'une condition de progression
enum ProgressionTier {
  COMMUNITY  // communautaire (échelle village / clan)
  INDIVIDUAL // personnelle (propre au joueur)
}

// Workflow d'une soumission de condition de progression
enum SubmissionStatus {
  PENDING
  VALIDATED
  REJECTED
}

// Raison d'un mouvement d'XP (audit immuable)
enum XPReason {
  ADMIN_GRANT             // admin crédite manuellement
  ADMIN_REMOVE            // admin retire manuellement
  REGISTRATION_BONUS      // crédit à la création de compte
  FORUM_SYNC              // delta calculé depuis la page profil Forumactif
  FICHE_VALIDATED         // débit lors de la validation d'une fiche
  FICHE_REJECTED_REFUND   // remboursement éventuel si validation annulée
  ARTS_SPEND              // dépense XP : expertise d'art, montée de spé, Kuchiyose
  QUINTESSENCE_SPEND      // dépense XP : quintessence d'art/KG, second KG
  PROGRESSION_SPEND       // dépense XP : « Dépenser X XP pour monter en Rang » (voie de progression)
}

// ============================================================
// MODELS
// ============================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String
  role          Role     @default(USER)
  canManageAdmins Boolean @default(false)

  // Économie XP — voir lib/xp.ts pour les dérivés (niveau).
  // Le niveau N'EST JAMAIS stocké : il est recalculé à la volée.
  xpAvailable   Int      @default(0) // monnaie dépensable
  xpTotalEarned Int      @default(0) // lifetime → drive le niveau
  version       Int      @default(0) // optimistic lock (cf. PLAYBOOK §2.3)

  // === Profil RP ===
  primaryKg       String?  // 1er Kekkei Genkai (choix joueur IRRÉVERSIBLE)
  primaryAffinity String?  // 1ère affinité élémentaire (choix joueur IRRÉVERSIBLE)
  clan          String?
  rang          Rang?    // legacy / miroir du champ "Rang" du forum (sync)
  // Les 3 rangs du jeu (E→S), gérés par le staff dans l'app :
  rangVillage   Rang?
  rangHistoire  Rang?
  rangClan      Rang?
  grade         Grade?
  artsState     Json?    // état des Arts Shinobi (rangs de spés, expertises) — cf. lib/arts.ts
  progressionState Json? // quintessences acquises + mode spécial — cf. lib/quintessence.ts
  uniteSpeciale String?
  trame         String?
  prime         String?
  age           Int?
  genre         String?
  kekkeiGenkai  String?
  affinites     String[] @default([])
  // Affinité(s) du pacte Kuchiyose (1ère verrouillée ; 2e via pré-stade Mode Ermite).
  pactAffinities String[] @default([])
  pactSpecies   String?  // Espèce du pacte Kuchiyose (verrouillée avec l'affinité)

  // === Sync forum Hi no Kuni ===
  forumProfileUrl    String?   // ex: https://hinokuni.forumactif.com/u1
  forumUserId        Int?      // ID numérique parsé de l'URL
  forumPseudo        String?   // dernier pseudo connu sur le forum
  forumAvatar        String?   // URL de l'avatar forum (CDN 2img.net)
  forumLastXp        Int?      // dernière valeur XP lue (pour calcul delta)
  forumLastRang      String?   // dernier rang lu (pour audit)
  forumPresentationUrl String?
  forumCarnetUrl     String?
  forumLastSyncAt    DateTime?
  forumLastSyncError String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  fiches          FicheTechnique[] @relation("FicheAuthor")
  fichesValidated FicheTechnique[] @relation("FicheValidator")
  xpHistory       XPTransaction[]  @relation("UserXP")
  xpActedOn       XPTransaction[]  @relation("ActorXP")
  invocations     Invocation[]     @relation("UserInvocations")
  progressionSubmissions ProgressionSubmission[] @relation("ProgSubmitter")
  progressionReviewed    ProgressionSubmission[] @relation("ProgReviewer")

  @@index([forumUserId])
}

// Invocation (Kuchiyose) — mini-profil rattaché à un joueur, avec sa
// propre liste de techniques (JSON [{nom, description}]).
model Invocation {
  id           String   @id @default(cuid())
  ownerId      String
  owner        User     @relation("UserInvocations", fields: [ownerId], references: [id], onDelete: Cascade)

  nom          String
  espece       String?
  affinite     String?  // legacy : affinité libre (remplacée par l'affinité de pacte héritée du joueur)
  artShinobi   String?  // Art Shinobi de l'animal (remplace le KG côté invocation)
  kekkeiGenkai String?  // KG : seulement si Mode Ermite stade 2 (KG partagé)
  image        String?  // URL d'illustration (optionnelle)
  description  String?  @db.Text
  techniques   Json?    // [{ nom, description }] (legacy ; techniques validées = FicheTechnique liées)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Techniques de Kuchiyose passées par la validation (FicheTechnique)
  fiches       FicheTechnique[] @relation("InvocationFiches")

  @@index([ownerId])
}

model FicheTechnique {
  id              String      @id @default(cuid())
  slug            String      @unique
  nom             String
  description     String      @db.Text

  // Métadonnées RP
  art             String?     // Art Shinobi : Ninjutsu, Taijutsu, Bukijutsu, Genjutsu, Fūinjutsu, Kanchijutsu, Kuchiyose
  spec            String?     // Spécialisation de l'Art Shinobi (ex : Clanique, Affinitaire, Neutre…)
  secondaryArt    String?     // 2e Art Shinobi (techniques de type COMBINEE)
  secondarySpec   String?     // Spécialisation du 2e Art (COMBINEE)
  actionType      String?     // Type d'action : EVOLUTIVE..SUPREME (drive le coût)
  element         String?     // affinité : Katon, Suiton, Doton, Raiton, Futon
  secondaryElement String?    // 2e affinité (COMBINEE : x2 affi ou KG/affi)
  kekkeiGenkai    String?     // si manifesté par un Kekkei Genkai (lequel)
  secondaryKekkeiGenkai String? // 2e KG (COMBINEE : x2 KG ou KG/affi)
  nature          String?     // PERSONNELLE | COLLECTIVE (clan / bibliothèque commune)
  kinjutsuScope   String?     // legacy (ancien scope Kinjutsu : CLAN | VILLAGE)
  clan            String?     // clan propriétaire (Nature COLLECTIVE → bibliothèque commune)
  type            String?     // legacy (ancien champ "type")
  rangMin         Rang?       // legacy (rang minimal)

  // Technique de Kuchiyose : rattachée à une invocation du joueur (sinon = perso)
  invocationId    String?
  invocation      Invocation? @relation("InvocationFiches", fields: [invocationId], references: [id], onDelete: SetNull)

  // Type d'action COLLECTIVE (jouée à 2-3) : participants co-payeurs
  collaborators   String[]    @default([]) // pseudos saisis (audit / affichage)
  collaboratorIds String[]    @default([]) // IDs résolus (partage du coût + affichage croisé)

  coutXp          Int         @default(0)

  status          FicheStatus @default(DRAFT)
  rejectionReason String?
  comment         String?     @db.Text // note temporaire du joueur (effacée à la décision)

  authorId        String
  author          User        @relation("FicheAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  validatedById   String?
  validatedBy     User?       @relation("FicheValidator", fields: [validatedById], references: [id], onDelete: SetNull)
  validatedAt     DateTime?

  // Soft delete : on n'efface jamais (préserve l'historique RP)
  isActive        Boolean     @default(true)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([authorId, status])
  @@index([status, createdAt])
  @@index([clan, status])
  @@index([invocationId])
}

model XPTransaction {
  id        String   @id @default(cuid())
  userId    String
  actorId   String?  // null = système (sync forum, bonus inscription)
  amount    Int      // signe + ou − (audit immuable)
  reason    XPReason
  metadata  Json?    // ex: { ficheId, ficheSlug, delta, syncFrom: "forum" }
  createdAt DateTime @default(now())

  user      User     @relation("UserXP",  fields: [userId],  references: [id], onDelete: Cascade)
  actor     User?    @relation("ActorXP", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([reason, createdAt])
}

// ============================================================
// Progression — soumission d'un RP pour UNE condition (Village/Clan/Histoire).
//
// Une ligne = un RP soumis pour faire avancer une condition (id stable défini
// dans lib/progression.ts). Compteur incrémental : une condition de type
// `count` est remplie quand le nombre de soumissions VALIDATED atteint sa cible.
//   - tier COMMUNITY  → partagée : scopeKey = "konoha" (village) ou nom du clan.
//                       Les soumissions VALIDATED du scope s'additionnent pour tous.
//   - tier INDIVIDUAL → scopeKey "self" : rattachée au seul joueur (userId).
//
// `condId` n'est pas une FK (les conditions vivent en config, pas en base).
// Plusieurs soumissions par condition sont autorisées (pas de contrainte
// d'unicité) — c'est le compteur incrémental.
// ============================================================
model ProgressionSubmission {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation("ProgSubmitter", fields: [userId], references: [id], onDelete: Cascade)

  track       ProgressionTrack
  tier        ProgressionTier
  targetRank  Rang             // palier visé (D..S)
  condId      String           // id de condition (cf. lib/progression.ts COND_CATALOG)
  scopeKey    String           // COMMUNITY : "konoha" | nom de clan ; INDIVIDUAL : "self"

  // Détail du RP soumis (justificatif).
  rpTitle     String?          // titre du RP
  rpUrl       String?          // lien vers le RP
  comment     String?          @db.Text // commentaire libre pour le staff
  collaborators   String[]     @default([]) // pseudos exacts saisis par le joueur
  collaboratorIds String[]     @default([]) // IDs résolus pour l'audit + la contrib

  status      SubmissionStatus @default(PENDING)
  rejectionReason String?

  reviewedById String?
  reviewedBy   User?           @relation("ProgReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([track, tier, scopeKey, status])
  @@index([userId, status])
  @@index([condId, status])
}

// Rang communautaire de base (« définir de base » côté staff).
// Le rang EFFECTIF = max(baseRank, rang dérivé des conditions remplies).
//   - scopeType VILLAGE → scopeKey "konoha" (une seule ligne).
//   - scopeType CLAN    → scopeKey = nom du clan normalisé (une ligne par clan).
model CommunityRank {
  id        String           @id @default(cuid())
  scopeType ProgressionTrack // VILLAGE | CLAN
  scopeKey  String
  baseRank  Rang             @default(E)
  updatedAt DateTime         @updatedAt

  @@unique([scopeType, scopeKey])
}

model KekkeiGenkaiCatalog {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClanLibraryPermission {
  id        String   @id @default(cuid())
  clan      String
  clanKey   String
  kind      String   // KG | AFFINITY
  value     String
  createdAt DateTime @default(now())

  @@unique([clanKey, kind, value])
  @@index([clanKey])
}
